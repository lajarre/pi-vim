{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowJs": false,
    "types": ["node"]
  },
  "include": [
    "*.ts",
    "script/**/*.ts",
    "test/**/*.ts"
  ]
}

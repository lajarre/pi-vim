{
  "name": "pi-vim",
  "version": "0.1.0",
  "description": "Vim-style modal editing for Pi's TUI editor",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "vim",
    "editor"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lajarre/pi-vim.git"
  },
  "files": [
    "*.ts",
    "!*.test.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "echo 'nothing to build'",
    "test": "node --import tsx/esm --test 'test/**/*.test.ts'",
    "check": "npm run test"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "devDependencies": {
    "tsx": "^4.19.3"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*"
  }
}
